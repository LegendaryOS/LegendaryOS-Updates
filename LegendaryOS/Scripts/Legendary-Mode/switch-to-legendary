#!/bin/bash

# SWITCH TO LEGENDARY MODE

set -e

kdialog --yesno "Czy chcesz przełączyć się na Legendary Mode?" || exit 0

echo "Stopping game sessions..."
pkill -f gamescope || true
pkill -f steam || true

echo "Starting required services..."
sudo systemctl start NetworkManager
sudo systemctl start bluetooth
sudo systemctl start gamemoded

# Uruchom vkBasalt jeśli jest dostępny
if command -v vkbasalt >/dev/null 2>&1; then
  export VK_INSTANCE_LAYERS=VK_LAYER_LUNARG_standard_validation
  export VK_LAYER_PATH=/usr/share/vkBasalt/
fi

echo "Launching Legendary Mode session..."
/usr/share/LegendaryOS/Scripts/Legendary-Mode/legendary-mode-session &

kdialog --msgbox "Legendary Mode uruchomiony."

exit 0
